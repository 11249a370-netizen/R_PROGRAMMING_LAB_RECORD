#Online Exam Result Analysis
# Data
grades <- c("A", "B", "C", "D")
 
count <- c(15, 25, 30, 10)
# Pie Chart
pie(
count,
labels = grades,
main = "Grade Distribution",
col = c("gold", "lightblue", "pink", "lightgreen")
)
# Bar Chart
barplot(
count,
names.arg = grades,
main = "Number of Students per Grade",
xlab = "Grade",
ylab = "Number of Students",
col = c("gold", "lightblue", "pink", "lightgreen")
)
